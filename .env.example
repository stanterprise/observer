# Docker Compose defaults (copy to .env and adjust as needed)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=observer
POSTGRES_PORT=5432

# NATS configuration
NATS_PORT=4222
NATS_HTTP_PORT=8222
NATS_URL=nats://localhost:4222
NATS_STREAM=tests_events
NATS_SUBJECT_PREFIX=tests.events.v1

# App connection string for local dev
DATABASE_URL=postgres://postgres:postgres@localhost:5432/observer?sslmode=disable

# Auto-apply schema on service start (optional)
APPLY_MIGRATIONS=1

# GKE Kubernetes cluster configuration (for development)
# Set these values to connect to your GKE cluster
# GKE_PROJECT=your-gcp-project-id
# GKE_CLUSTER=observer-dev
# GKE_REGION=us-central1
# GKE_ZONE=                      # Use for zonal clusters instead of region
