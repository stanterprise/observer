# Docker Compose defaults (copy to .env and adjust as needed)

# ============================================================================
# MongoDB Configuration (for document-based backend)
# ============================================================================
MONGO_USER=root
MONGO_PASSWORD=password
MONGO_DATABASE=observer
MONGO_PORT=27017

# MongoDB connection string (recommended)
MONGODB_URI=mongodb://root:password@localhost:27017/observer?authSource=admin

# ============================================================================
# PostgreSQL Configuration (relational execution store)
# ============================================================================
POSTGRES_USER=observer
POSTGRES_PASSWORD=observer
POSTGRES_DB=observer
POSTGRES_PORT=5432

# PostgreSQL DSN (set to enable relational execution; optional)
# POSTGRES_DSN=postgres://observer:observer@localhost:5432/observer?sslmode=disable

# ============================================================================
# NATS Configuration
# ============================================================================
# Legacy SQL backend variables (deprecated):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/observer?sslmode=disable
# APPLY_MIGRATIONS=1
# ============================================================================
# For PostgreSQL/SQLite (legacy):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/observer?sslmode=disable

# For MongoDB (recommended for new deployments):
# MONGODB_URI=mongodb://root:password@localhost:27017/observer?authSource=admin

# Auto-apply schema on service start (SQL backend only)
APPLY_MIGRATIONS=1

# ============================================================================
# Relational Execution Configuration
# ============================================================================
# TTL for MongoDB live step buffer documents (Go duration, default: 15m)
# MONGO_STEP_BUFFER_TTL=15m

# Step payload size threshold before offloading to object storage (bytes, default: 4194304 = 4MB)
# STEP_PAYLOAD_THRESHOLD=4194304
