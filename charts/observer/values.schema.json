{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["aio", "distributed"]
    },
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string" },
        "pullPolicy": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "podAnnotations": {
      "type": "object"
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "aio": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
            },
            "webPort": { "type": "integer", "minimum": 1 },
            "grpcPort": { "type": "integer", "minimum": 1 },
            "apiPort": { "type": "integer", "minimum": 1 },
            "natsPort": { "type": "integer", "minimum": 1 },
            "natsMonitoringPort": { "type": "integer", "minimum": 1 }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClass": { "type": "string" },
            "accessMode": { "type": "string" },
            "size": { "type": "string", "minLength": 1 }
          }
        },
        "grpcLoadBalancer": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "port": { "type": "integer", "minimum": 1 },
            "annotations": { "type": "object" }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        }
      }
    },
    "distributed": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingestion": { "$ref": "#/definitions/distributedWorkloadWithService" },
        "processor": { "$ref": "#/definitions/distributedWorkload" },
        "api": { "$ref": "#/definitions/distributedWorkloadWithService" },
        "web": {
          "allOf": [
            { "$ref": "#/definitions/distributedWorkloadWithService" },
            {
              "type": "object",
              "properties": {
                "securityContext": { "type": "object" }
              }
            }
          ]
        }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1 },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "database": { "type": "string" },
        "sslmode": { "type": "string" },
        "migration": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "backoffLimit": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "mongodb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1 },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "database": { "type": "string" },
        "authSource": { "type": "string" }
      }
    },
    "nats": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "externalNats": {
      "type": "object",
      "properties": {
        "url": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "existingSecret": { "type": "string" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "aioSecurityContext": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": { "const": "aio" }
        }
      },
      "then": {
        "properties": {
          "aio": {
            "type": "object",
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": { "const": "distributed" }
        }
      },
      "then": {
        "properties": {
          "distributed": {
            "type": "object",
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": { "const": "distributed" },
          "nats": {
            "type": "object",
            "properties": {
              "enabled": { "const": false }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "externalNats": {
            "type": "object",
            "properties": {
              "url": { "type": "string", "minLength": 1 }
            },
            "required": ["url"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": { "const": "distributed" },
          "postgresql": {
            "type": "object",
            "properties": {
              "enabled": { "const": false }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "postgres": {
            "type": "object",
            "properties": {
              "host": { "type": "string", "minLength": 1 }
            },
            "required": ["host"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": { "const": "distributed" },
          "mongodb": {
            "type": "object",
            "properties": {
              "enabled": { "const": false }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "externalDatabase": {
            "type": "object",
            "properties": {
              "host": { "type": "string", "minLength": 1 }
            },
            "required": ["host"]
          }
        }
      }
    }
  ],
  "definitions": {
    "distributedWorkload": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "minimum": 1
            },
            "targetMemoryUtilizationPercentage": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] },
          "not": {
            "anyOf": [
              { "required": ["NATS_URL"] },
              { "required": ["POSTGRES_DSN"] },
              { "required": ["MONGODB_URI"] }
            ]
          }
        }
      }
    },
    "distributedWorkloadWithService": {
      "allOf": [
        { "$ref": "#/definitions/distributedWorkload" },
        {
          "type": "object",
          "properties": {
            "service": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
                },
                "port": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      ]
    }
  }
}
