# Dockerfile for Processor service
# Consumes events from NATS and writes to database

# ============================================================================
# Builder stage
# ============================================================================
FROM golang:1.25-alpine AS builder

# Install ca-certificates for HTTPS connections
RUN apk add --no-cache ca-certificates

WORKDIR /build

# Copy go mod files and download dependencies (cached layer)
COPY go.mod go.sum ./
RUN go mod download && go mod verify

# Copy only necessary source files
COPY cmd/processor/ ./cmd/processor/
COPY pkg/ ./pkg/
COPY internal/ ./internal/

# Build processor binary
# TARGETARCH is automatically set by BuildKit for multi-platform builds
ARG TARGETARCH
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} \
    go build -ldflags='-w -s' \
    -o /bin/processor ./cmd/processor

# ============================================================================
# Runtime stage
# ============================================================================
FROM alpine:3.20

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata

# Copy processor binary from builder
COPY --from=builder /bin/processor /usr/local/bin/processor

# Environment variables
ENV NATS_URL=nats://nats:4222 \
    NATS_STREAM=tests_events \
    NATS_CONSUMER=processor \
    APPLY_MIGRATIONS=1

# Run processor service
CMD ["/usr/local/bin/processor"]
