# Dockerfile for Web UI
# Multi-stage build: Node.js for building, Nginx for serving

# ============================================================================
# Builder stage - Build React application
# ============================================================================
FROM node:20-alpine AS builder

WORKDIR /build

# Copy package files (cached layer)
COPY web/package*.json ./

# Install all dependencies (including dev deps needed for build)
RUN npm ci --ignore-scripts

# Copy source code
COPY web/ ./

# Build the application
RUN npm run build

# ============================================================================
# Runtime stage - Nginx for serving static files and proxying
# ============================================================================
FROM nginx:alpine

# Copy built application from builder
COPY --from=builder /build/dist /usr/share/nginx/html

# Copy Nginx server block template for distributed web mode.
# This file is rendered into /etc/nginx/conf.d/default.conf by nginx entrypoint.
COPY docker/nginx/nginx.web.conf.template /etc/nginx/templates/default.conf.template

# Environment variables for backend configuration
# These will be substituted in the web nginx template by envsubst
ENV API_BACKEND_HOST=localhost \
    API_BACKEND_PORT=8080

# Expose HTTP port
EXPOSE 80

# Use default nginx entrypoint which handles template substitution
# The nginx image automatically runs envsubst on files in /etc/nginx/templates/
CMD ["nginx", "-g", "daemon off;"]
