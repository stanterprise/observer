# Local development environment variables for web UI
# Copy this file to .env.development.local and adjust as needed

# When running web UI locally with `npm run dev` while other services run in Docker Compose:
# 1. Start infrastructure: docker compose --profile web-dev up -d
# 2. Run web dev server: npm run dev
#
# The Vite proxy in vite.config.ts will forward /api and /ws requests to localhost:8080
# which is the API service exposed from Docker Compose

# Uncomment these if you need to override the defaults:
# VITE_API_URL=/api
# VITE_WS_URL=ws://localhost:3000/ws
